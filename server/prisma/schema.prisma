generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Code {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  status      String   @default("new")
  createdAt   DateTime @default(now())
  activatedAt DateTime?
}